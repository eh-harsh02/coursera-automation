<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">

<suite name="Parallel Browser Suite" parallel="tests" thread-count="2">
	<listeners>
		<listener class-name="extentReportListner.ExtentReportManager" />
	</listeners>
	<!-- Chrome execution -->
	<test name="Chrome Test">
		<parameter name="browser" value="chrome" />
		<classes>
			<class name="tests.TestLandingPage" />
			<class name="tests.TestSearchResultsPage" />
			<class name="tests.TestCourseDetailsPage" />
			<class name="tests.TestEnterprisePage" />
		</classes>
	</test>
	
	<!-- Edge execution -->
